{
  "name": "mixaudio",
  "version": "0.1.3",
  "description": "Adaptive game music DSL compiler, browser player, and studio.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mixaudio": "./bin/mixaudio.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amir-s/unshuffle-music.git"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"const fs=require('node:fs'); for (const path of ['dist','.next']) fs.rmSync(path,{ recursive: true, force: true });\"",
    "build:lib": "tsup",
    "build:studio": "node scripts/build-studio.mjs",
    "build": "npm run clean && npm run build:lib && npm run build:studio",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "node --test src/index.test.ts src/mix-player.test.ts src/lib/*.test.ts",
    "test:cli": "node --test src/cli.test.ts",
    "test": "npm run test:unit && npm run test:cli",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.2",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-code-editor": "^0.14.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
